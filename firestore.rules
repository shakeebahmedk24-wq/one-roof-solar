rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'shakeebahmed054@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(pageId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(serviceId);
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(productId);
    }

    match /systems/{systemId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(systemId);
    }
  }
}
